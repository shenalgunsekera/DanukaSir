rules_version = '2';

// ─────────────────────────────────────────────────────────────
//  Firestore Security Rules — Adeesha Tutor Platform
//
//  Model:
//   - The tutor (owner) is the only authenticated user. Replace
//     OWNER_EMAIL below with Adeesha's login email.
//   - Public visitors can READ the profile and APPROVED reviews,
//     and may CREATE a pending review (never read others' pending).
//   - Students collection is owner-only. Parents never authenticate;
//     they read progress through a server route that validates the
//     access token + code server-side using the Admin SDK, which
//     bypasses these rules. Therefore students stay fully locked here.
// ─────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner() {
      return request.auth != null
        && request.auth.token.email == 'adeesha@example.com'; // <-- set OWNER_EMAIL
    }

    // Public tutor profile — read by anyone, written only by owner.
    match /profile/{doc} {
      allow read: if true;
      allow write: if isOwner();
    }

    // Reviews — public can read APPROVED only; anyone can submit a
    // pending review; only the owner can moderate/delete.
    match /reviews/{id} {
      allow read: if resource.data.status == 'approved' || isOwner();
      allow create: if request.resource.data.status == 'pending'
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.body is string
        && request.resource.data.body.size() <= 1200;
      allow update, delete: if isOwner();
    }

    // Students — owner only. Parent access is mediated server-side
    // via the Admin SDK (token + code), never the client.
    match /students/{id} {
      allow read, write: if isOwner();
    }

    // Consultation bookings — anyone can submit a "new" request;
    // only the owner can read, update status, or delete.
    match /bookings/{id} {
      allow create: if request.resource.data.status == 'new'
        && request.resource.data.email is string
        && request.resource.data.studentName is string;
      allow read, update, delete: if isOwner();
    }

    // Study materials — public can read published notes; owner manages.
    match /notes/{id} {
      allow read: if resource.data.published == true || isOwner();
      allow write: if isOwner();
    }

    // Purchases — anyone can submit a pending purchase (with a slip);
    // only the owner can read/verify/delete them.
    match /purchases/{id} {
      allow create: if request.resource.data.status == 'pending'
        && request.resource.data.email is string;
      allow read, update, delete: if isOwner();
    }
  }
}
