# ─────────────────────────────────────────────────────────────
#  Danuka Tutor Platform — Environment Variables
#  Copy this file to ".env.local" and fill in your Firebase keys.
#
#  STORAGE: This build uses a FREE local folder store for images &
#  documents (public/uploads via /api/upload). Firebase Storage is
#  NOT used or required — no billing needed.
#
#  DATABASE: Set the Firebase Admin (service account) values below to
#  persist all data in Firestore (free Spark tier is enough). Until
#  they are set, the app runs in DEMO MODE with seeded sample data.
# ─────────────────────────────────────────────────────────────

# --- Firestore via Firebase Admin SDK (REQUIRED for persistence) ---
# From Firebase Console > Project Settings > Service accounts >
# "Generate new private key". Open the downloaded JSON and copy:
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Keep the surrounding quotes and the literal \n escape sequences:
FIREBASE_ADMIN_PRIVATE_KEY=""

# --- Firebase Web SDK (OPTIONAL) ---
# Only needed if you want real Firebase Authentication for the dashboard
# login. Leave blank to use the simple owner-email login (free, no setup).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# The tutor's login email (locks the dashboard to the owner)
NEXT_PUBLIC_OWNER_EMAIL=danuka@example.com

# Public site URL (used when generating parent report links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Secret protecting the one-time seed endpoint (POST /api/seed?secret=...)
SEED_SECRET=change-me-to-a-long-random-string
